# EcoAgent -- IBM watsonx.ai credentials
# Region: eu-de (Frankfurt)
# Platform: https://eu-de.dataplatform.cloud.ibm.com

# IBM Cloud API Key
WATSONX_API_KEY="your-api-key"

# watsonx.ai REST endpoint for eu-de region
WATSONX_URL=https://eu-de.ml.cloud.ibm.com

# watsonx.ai Studio Project ID
# How to get it:
#   1. Go to https://eu-de.dataplatform.cloud.ibm.com
#   2. Open your project (or create one if none exists)
#   3. Go to the Manage tab -> General -> copy the Project ID (UUID)
WATSONX_PROJECT_ID="your-project-id"
